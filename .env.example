# ============================================================================
# Limpa Nome Expresso - Environment Variables Configuration
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase Configuration (Required)
# ----------------------------------------------------------------------------
# Get your credentials at: https://supabase.com/dashboard/project/_/settings/api
#
# VITE_SUPABASE_URL: Your Supabase project URL
# - Found in Supabase Dashboard > Settings > API > Project URL
# - Required for both client and server
# - Format: https://your-project-id.supabase.co
#
# VITE_SUPABASE_ANON_KEY: Anonymous/public key for client-side access
# - Found in Supabase Dashboard > Settings > API > anon/public key
# - Safe to expose in client code (has limited permissions)
# - Required for client-side Supabase client
#
# VITE_SUPABASE_SERVICE_ROLE_KEY: Service role key for server-side admin access
# - Found in Supabase Dashboard > Settings > API > service_role key
# - NEVER expose this in client code (bypasses RLS)
# - Required for server operations (user creation, admin functions)
#
# SUPABASE_URL: Same as VITE_SUPABASE_URL (for server-side imports)
# SUPABASE_SERVICE_ROLE_KEY: Same as VITE_SUPABASE_SERVICE_ROLE_KEY (for server-side)
# ----------------------------------------------------------------------------

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----------------------------------------------------------------------------
# EmailIt API Configuration (Optional - Registration works without it)
# ----------------------------------------------------------------------------
# Get your API key at: https://emailit.com
#
# EMAILIT_API_KEY: Your EmailIt API key for sending emails
# - Registration will work without this (graceful degradation)
# - Users will be created in Supabase but no confirmation email sent
# - Get it from: https://emailit.com/dashboard/api-keys
#
# EMAILIT_DEFAULT_FROM: Default sender email address
# - Must be a verified domain in your EmailIt account
# - Format: noreply@yourdomain.com
# - Used as the "from" address for all system emails
# ----------------------------------------------------------------------------

EMAILIT_API_KEY=your-emailit-api-key
EMAILIT_DEFAULT_FROM=noreply@yourdomain.com

# ----------------------------------------------------------------------------
# Stripe Configuration (Optional - for payment features)
# ----------------------------------------------------------------------------
# Get your keys at: https://dashboard.stripe.com/apikeys
#
# STRIPE_SECRET_KEY: Secret key for server-side Stripe operations
# - Starts with sk_test_ for test mode
# - Starts with sk_live_ for production
# - NEVER expose in client code
#
# STRIPE_WEBHOOK_SECRET: Webhook signing secret for Stripe events
# - Used to verify incoming webhook requests from Stripe
# - Found in: Stripe Dashboard > Developers > Webhooks > Signing secret
#
# VITE_STRIPE_PUBLIC_KEY: Publishable key for client-side Stripe
# - Starts with pk_test_ for test mode
# - Starts with pk_live_ for production
# - Safe to expose in client code
# ----------------------------------------------------------------------------

STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
VITE_STRIPE_PUBLIC_KEY=pk_test_your_public_key_here

# ----------------------------------------------------------------------------
# MercadoPago Configuration (Optional - for payment features)
# ----------------------------------------------------------------------------
# Get your credentials at: https://www.mercadopago.com.br/developers
#
# MERCADOPAGO_ACCESS_TOKEN: Access token for MercadoPago API
# - Production access token from MercadoPago dashboard
# - NEVER expose in client code
# - Used for creating payment preferences and managing subscriptions
# ----------------------------------------------------------------------------

MERCADOPAGO_ACCESS_TOKEN=your-mercado-pago-access-token

# ----------------------------------------------------------------------------
# Kiwify Configuration (Optional - for payment features)
# ----------------------------------------------------------------------------
# Get your credentials at: https://kiwify.com.br
#
# KIWIFY_CLIENT_ID: OAuth client ID for Kiwify API authentication
# - Found in: Kiwify Dashboard > Apps > API > Criar API Key
# - UUID format (e.g., 21f3b7c4-2734-44d5-9923-7de0848558bb)
# - Required for OAuth token generation
#
# KIWIFY_CLIENT_SECRET: OAuth client secret for Kiwify API authentication
# - Found in: Kiwify Dashboard > Apps > API > Criar API Key
# - NEVER expose in client code
# - Required for OAuth token generation
#
# KIWIFY_ACCOUNT_ID: Kiwify account identifier
# - Found in: Kiwify Dashboard > Apps > API
# - Used as x-kiwify-account-id header in API requests
# - Required for multi-tenant isolation
#
# KIWIFY_WEBHOOK_TOKEN: Token for verifying webhook requests
# - Configured when setting up webhooks in Kiwify dashboard
# - Used to verify incoming webhook authenticity
# - Prevents unauthorized webhook requests
# ----------------------------------------------------------------------------

KIWIFY_CLIENT_ID=your-kiwify-client-id
KIWIFY_CLIENT_SECRET=your-kiwify-client-secret
KIWIFY_ACCOUNT_ID=your-kiwify-account-id
KIWIFY_WEBHOOK_TOKEN=your-kiwify-webhook-token
KIWIFY_PRODUCT_SLUG=cpf-blindado-premium
KIWIFY_PRODUCT_SLUG=cpf-blindado-premium

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------
# PORT: Server port (default: 3001)
# NODE_ENV: Environment mode (development | production | test)
# ----------------------------------------------------------------------------

PORT=3001
NODE_ENV=development

# ============================================================================
# TROUBLESHOOTING GUIDE
# ============================================================================

# Problem: Registration returns 503 "Serviço de autenticação indisponível"
# Solution: Check that VITE_SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are set
#   - Verify keys at: https://supabase.com/dashboard/project/_/settings/api
#   - Ensure both VITE_SUPABASE_URL and SUPABASE_URL are set to the same value
#   - Ensure both service role keys are set correctly

# Problem: Email not sent after registration
# Solution: Check EMAILIT_API_KEY configuration
#   - Registration still works without email (graceful degradation)
#   - User is created in Supabase but no confirmation email sent
#   - Check server logs for "EMAILIT_API_KEY not configured" warning
#   - Get API key from: https://emailit.com/dashboard/api-keys
#   - Verify your sender domain in EmailIt dashboard

# Problem: CORS errors when calling API from frontend
# Solution: Add your domain to allowedOrigins in server/index.ts
#   - Example: allowedOrigins: ['http://localhost:5173', 'https://yourdomain.com']
#   - Restart server after updating origins

# Problem: User already exists error
# Solution: Check Supabase auth.users table
#   - Go to: https://supabase.com/dashboard/project/_/auth/users
#   - Search for the email address
#   - Delete the test user if needed

# Problem: "Invalid email" or "Invalid password" errors
# Solution: Check validation requirements
#   - Email must be valid format: local@domain.tld
#   - Password must be at least 6 characters
#   - Check browser console for validation errors

# Problem: Tests failing with "VITE_SUPABASE_URL not set"
# Solution: Load environment variables before running tests
#   - Run: export $(cat .env.local | grep -v '^#' | xargs) && npm test
#   - Or create a .env.test file with test credentials

# Problem: Kiwify webhooks returning 401 Unauthorized
# Solution: Check KIWIFY_WEBHOOK_TOKEN configuration
#   - Verify the token matches the one configured in Kiwify dashboard
#   - Go to: Kiwify Dashboard > Apps > API > Webhooks
#   - Ensure the webhook URL is correctly configured
#   - Check server logs for token verification errors

# Problem: Kiwify OAuth token generation failing
# Solution: Verify KIWIFY_CLIENT_ID and KIWIFY_CLIENT_SECRET
#   - Check credentials at: Kiwify Dashboard > Apps > API
#   - Ensure client_id is in UUID format
#   - Ensure client_secret is correctly copied (no trailing spaces)
#   - Verify KIWIFY_ACCOUNT_ID is set correctly

# ============================================================================
# SECURITY NOTES
# ============================================================================

# NEVER commit .env.local or any file containing real credentials
# ALWAYS use .env.example as a template (no real values)
# NEVER expose SERVICE_ROLE_KEY or SECRET_KEY in client code
# ALWAYS use different keys for development and production
# REGULARLY rotate your API keys and secrets
# KEEP webhook secrets secure to prevent request forgery

# ============================================================================
# ENVIRONMENT FILES PRIORITY
# ============================================================================

# 1. .env.local - Your local development (gitignored)
# 2. .env.test - Test environment (gitignored)
# 3. .env.production - Production (gitignored, deployed separately)
# 4. .env.example - Template (committed, no real values)
